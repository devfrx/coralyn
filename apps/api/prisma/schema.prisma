generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Establishment {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  customers Customer[]
  users     User[]
  sectors   Sector[]
  rows      Row[]
  umbrellas Umbrella[]
  types     UmbrellaType[]
  timeSlots TimeSlot[]
  bookings  Booking[]
}

model Customer {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  firstName       String
  lastName        String
  phone           String?
  email           String?
  notes           String?
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  bookings        Booking[]

  @@index([establishmentId])
}

enum Role {
  admin
  staff
  superuser
}

enum BookingType {
  daily
  periodic
  subscription
}

enum BookingStatus {
  confirmed
  cancelled
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

enum PaymentMethod {
  cash
  card
  transfer
  other
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  establishmentId String?        @db.Uuid // null = platform superuser (cross-tenant)
  email           String         @unique // globally unique: identifies the user at login
  passwordHash    String // argon2id; never exposed in DTOs
  role            Role
  establishment   Establishment? @relation(fields: [establishmentId], references: [id])

  @@index([establishmentId])
}

model UmbrellaType {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  name            String
  sortOrder       Int
  icon            String? // ui-kit icon-registry key (ADR-0020); null = no marker
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  umbrellas       Umbrella[]

  @@index([establishmentId])
}

model TimeSlot {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  name            String
  startTime       DateTime      @db.Time(0) // not exposed in the DTO (ADR-0013)
  endTime         DateTime      @db.Time(0)
  sortOrder       Int
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  bookings        Booking[]

  @@index([establishmentId])
}

model Sector {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  name            String
  sortOrder       Int
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  rows            Row[]

  @@index([establishmentId])
}

model Row {
  id              String        @id @default(uuid()) @db.Uuid
  establishmentId String        @db.Uuid
  sectorId        String        @db.Uuid
  label           String
  sortOrder       Int
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  sector          Sector        @relation(fields: [sectorId], references: [id])
  umbrellas       Umbrella[]

  @@index([establishmentId])
  @@index([sectorId])
}

model Umbrella {
  id                   String        @id @default(uuid()) @db.Uuid
  establishmentId      String        @db.Uuid
  rowId                String        @db.Uuid
  umbrellaTypeId       String?       @db.Uuid // null = Normal (ADR-0016)
  label                String // real physical number, unique per Establishment (ADR-0016)
  logicalOrder         Int
  presentationPosition Json?         @db.JsonB // visual layer (D-005): modeled, unused in this slice
  establishment        Establishment @relation(fields: [establishmentId], references: [id])
  row                  Row           @relation(fields: [rowId], references: [id])
  type                 UmbrellaType? @relation(fields: [umbrellaTypeId], references: [id])
  bookings             Booking[]

  @@unique([establishmentId, label])
  @@index([establishmentId])
  @@index([rowId])
}

model Booking {
  id                String         @id @default(uuid()) @db.Uuid
  establishmentId   String         @db.Uuid
  customerId        String         @db.Uuid
  umbrellaId        String         @db.Uuid
  timeSlotId        String         @db.Uuid
  previousBookingId String?        @db.Uuid // rinnovo self-link (ADR-0012); null in A1
  startDate         DateTime       @db.Date
  endDate           DateTime       @db.Date
  type              BookingType
  status            BookingStatus
  totalPrice        Decimal        @db.Decimal(10, 2)
  extras            Json?          @db.JsonB
  paymentStatus     PaymentStatus  @default(unpaid)
  amountCollected   Decimal        @default(0) @db.Decimal(10, 2)
  paymentMethod     PaymentMethod?
  collectionDate    DateTime?      @db.Date
  createdAt         DateTime       @default(now())

  establishment    Establishment @relation(fields: [establishmentId], references: [id])
  customer         Customer      @relation(fields: [customerId], references: [id])
  umbrella         Umbrella      @relation(fields: [umbrellaId], references: [id])
  timeSlot         TimeSlot      @relation(fields: [timeSlotId], references: [id])
  previousBooking  Booking?      @relation("BookingRenewal", fields: [previousBookingId], references: [id])
  renewals         Booking[]     @relation("BookingRenewal")

  @@index([establishmentId])
  @@index([umbrellaId])
  @@index([establishmentId, startDate, endDate])
}
