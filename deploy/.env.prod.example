# ==========================================================================
# Coralyn — TEMPLATE dei segreti di PRODUZIONE.
# Copia questo file in .env.prod (nella root del repo) e riempi i valori.
#   cp deploy/.env.prod.example .env.prod
# .env.prod NON va MAI committato (è già in .gitignore).
# ==========================================================================

# ---- Domini (senza https://). Devono avere un record DNS A che punta al VPS. ----
DOMAIN_STAFF=app.tuodominio.it
DOMAIN_PLATFORM=platform.tuodominio.it
DOMAIN_CUSTOMER=my.tuodominio.it
ACME_EMAIL=tua-email@esempio.it

# ---- Postgres (superuser del DB: usato solo per creare il ruolo app + backup) ----
POSTGRES_USER=coralyn
# Genera con: openssl rand -base64 24
POSTGRES_PASSWORD=CAMBIAMI_password_superuser_db
POSTGRES_DB=coralyn_prod

# ---- Ruolo applicativo RLS (coralyn_app, NON-superuser: è quello che usa l'API) ----
# Usa SOLO lettere e numeri qui (finisce sia nell'init SQL sia nel DATABASE_URL).
# Genera con: openssl rand -hex 24
APP_DB_PASSWORD=CAMBIAMI_password_ruolo_app
# DATABASE_URL: deve combaciare con APP_DB_PASSWORD e POSTGRES_DB qui sopra.
# host = 'db' (nome del servizio compose). Porta interna 5432.
DATABASE_URL=postgresql://coralyn_app:CAMBIAMI_password_ruolo_app@db:5432/coralyn_prod?schema=public

# ---- Auth staff/piattaforma (ADR-0024 / ADR-0025) ----
# Almeno 32 caratteri casuali. Genera con: openssl rand -base64 48
JWT_SECRET=CAMBIAMI_almeno_32_caratteri_casuali_veri
JWT_EXPIRES_IN=8h

# ---- Primo superuser di piattaforma (il TUO primo login) ----
# Creato una tantum dallo script db:bootstrap-superuser (vedi guida, Passo 7).
PLATFORM_SUPERUSER_EMAIL=super@tuodominio.it
PLATFORM_SUPERUSER_PASSWORD=CAMBIAMI_password_forte_superuser

# ---- Seed: SPENTO in produzione (niente lido demo). Non toccare. ----
SEED_ON_START=false

# ---- Email transazionale (ADR-0042): inviti set-password e credenziali cliente. ----
# Esempio con Resend (https://resend.com). Con altri provider cambia host/porta/credenziali.
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=resend
MAIL_PASS=CAMBIAMI_api_key_del_provider_email
# Il dominio del mittente va verificato presso il provider (record SPF/DKIM su DNS).
MAIL_FROM=Coralyn <no-reply@tuodominio.it>
CREDENTIAL_TOKEN_TTL_HOURS=72

# ---- URL pubblici (finiscono nei link/QR degli inviti). Con https://. ----
APP_WEB_STAFF_URL=https://app.tuodominio.it
CUSTOMER_APP_URL=https://my.tuodominio.it
